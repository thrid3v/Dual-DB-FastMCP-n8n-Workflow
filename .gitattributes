# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# JSON
*.json text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown/Text
*.md text eol=lf
*.txt text eol=lf
README text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yaml text eol=lf

# Binary files
*.pyc binary
*.pyo binary
*.pyd binary
