# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Postgres
POSTGRES_PASSWORD=your_postgres_password_here
# MySQL
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here

# Optional: server DB connection overrides used by server.py
#PG_HOST=localhost
#PG_DATABASE=analytics
#PG_USER=admin
#PG_PASSWORD=your_postgres_password_here
#PG_PORT=5432

#MYSQL_HOST=localhost
#MYSQL_DATABASE=inventory
#MYSQL_USER=root
#MYSQL_PASSWORD=your_mysql_root_password_here
#MYSQL_PORT=3306
